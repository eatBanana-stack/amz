        <TableToolbarButton TItem="AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View" Icon="fa fa-tasks" Color="Color.Primary" Text="@WtmBlazor.Localizer["Sys.Import"]"  OnClickCallback="(x)=>OnImportClick()" />
    }
