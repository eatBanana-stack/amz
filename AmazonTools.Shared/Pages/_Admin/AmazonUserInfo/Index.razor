    {
        <TableToolbarButton TItem="AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View" Icon="fa fa-arrow-circle-down" Color="Color.Primary" Text="@WtmBlazor.Localizer["Sys.Export"]" OnClickCallback="(x)=>OnExportClick()" IsAsync="true" />
    }
  </TableToolbarTemplate>

</Table>



@code {
    [Parameter]
    public string id { get; set; }
    [Parameter]
    public string[] ids { get; set; }
    private AmazonUserInfoListVM Model = new AmazonUserInfoListVM();
    private Table<AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View> AmazonUserInfoListVMdataTable;
    private async Task AmazonUserInfoListVMDoSearch()
    {
        await AmazonUserInfoListVMdataTable.QueryAsync();
    }
    private async Task<QueryData<AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View>> AmazonUserInfoListVMOnSearchAmazonUserInfo(QueryPageOptions opts)
    {
            
        return await StartSearch<AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View>("/api/_Admin/AmazonUserInfo/SearchAmazonUserInfo", Model.Searcher, opts);
    }
    private async Task OnCreateClick()
    {
        var id = AmazonUserInfoListVMdataTable.SelectedRows?.Select(x => x.ID.ToString())?.FirstOrDefault();
        if (await OpenDialog<Create>(@WtmBlazor.Localizer["Sys.Create"], x => x.id == (id ?? ""), isMax:false) == DialogResult.Yes)
        {
            await AmazonUserInfoListVMdataTable.QueryAsync();
        }
    }

    private async Task OnEditClick(AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View item)
    {
        if (await OpenDialog<Edit>(@WtmBlazor.Localizer["Sys.Edit"], x => x.id == item.ID.ToString(), isMax:false) == DialogResult.Yes)
        {
            await AmazonUserInfoListVMdataTable.QueryAsync();
        }
    }

    private async Task OnDetailsClick(AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View item)
    {
        if (await OpenDialog<Details>(@WtmBlazor.Localizer["Page.详情"], x => x.id == item.ID.ToString(), isMax:false) == DialogResult.Yes)
        {
            await AmazonUserInfoListVMdataTable.QueryAsync();
        }
    }

    private async Task OnDeleteClick(AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View item)
    {
        await PostsData(new List<string> { item.ID.ToString() }, $"/api/_Admin/AmazonUserInfo/batchdelete", (s) => "Sys.OprationSuccess");
        await AmazonUserInfoListVMdataTable.QueryAsync();
    }

    private async Task OnBatchDeleteClick()
    {
        if (AmazonUserInfoListVMdataTable.SelectedRows?.Any() == true)
        {
            await PostsData(AmazonUserInfoListVMdataTable.SelectedRows.Select(x => x.ID.ToString()).ToList(), $"/api/_Admin/AmazonUserInfo/batchdelete", (s) => WtmBlazor.Localizer["Sys.BatchDeleteSuccess", s]);
            await AmazonUserInfoListVMdataTable.QueryAsync();
        }
        else
        {
            await WtmBlazor.Toast.Information(WtmBlazor.Localizer["Sys.Info"], WtmBlazor.Localizer["Sys.SelectOneRowMin"]);
        }
    }

    private async Task OnBatchEditClick()
    {
        if (AmazonUserInfoListVMdataTable.SelectedRows?.Any() == true)
        {
            if (await OpenDialog<BatchEdit>(WtmBlazor.Localizer["Sys.BatchEdit"], x => x.ids == AmazonUserInfoListVMdataTable.SelectedRows.Select(x => x.ID.ToString()).ToArray(), isMax:false) == DialogResult.Yes)
            {
                await AmazonUserInfoListVMdataTable.QueryAsync();
            }
        }
        else
        {
            await WtmBlazor.Toast.Information(WtmBlazor.Localizer["Sys.Info"], WtmBlazor.Localizer["Sys.SelectOneRowMin"]);
        }
    }

    private async Task OnImportClick()
    {
        var id = AmazonUserInfoListVMdataTable.SelectedRows?.Select(x => x.ID.ToString())?.FirstOrDefault();
        if (await OpenDialog<Import>(@WtmBlazor.Localizer["Sys.Import"], x => x.id == (id ?? ""), isMax:false) == DialogResult.Yes)
        {
            await AmazonUserInfoListVMdataTable.QueryAsync();
        }
    }

    private async Task OnExportClick()
    {
        if (AmazonUserInfoListVMdataTable.SelectedRows?.Any() == true)
        {
            await Download("/api/_Admin/AmazonUserInfo/AmazonUserInfoExportExcelByIds", AmazonUserInfoListVMdataTable.SelectedRows.Select(x => x.ID.ToString()).ToList());
        }
        else
        {
            await Download("/api/_Admin/AmazonUserInfo/AmazonUserInfoExportExcel", Model.Searcher);
        }
    }

    
    protected override async Task OnInitializedAsync()
    {
        
        

        await base.OnInitializedAsync();
    }
}
