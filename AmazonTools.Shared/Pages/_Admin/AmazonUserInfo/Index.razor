<Table @ref="AmazonUserInfoListVMdataTable" TItem="AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View" OnQueryAsync="AmazonUserInfoListVMOnSearchAmazonUserInfo" 
                IsStriped="true" IsBordered="true" ShowRefresh="false" ShowExtendEditButton="false" ShowExtendDeleteButton="false" 
                ShowToolbar="true" IsMultipleSelect="true" ShowExtendButtons="true"
                ShowDefaultButtons="false" IsPagination="true">
  <TableColumns>
    <TableColumn @bind-Field="@context.AmazonUserInfo_FaUserNameCn" Text="@WtmBlazor.Localizer["Page.姓名中文"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_FaUserNameUs" Text="@WtmBlazor.Localizer["Page.姓名拼音"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_FaIdCard" Text="@WtmBlazor.Localizer["Page.身份证"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_FaBornTime" Text="@WtmBlazor.Localizer["Page.出生时间"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_FaEndTime" Text="@WtmBlazor.Localizer["Page.有效时间"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_LicenseCn" Text="@WtmBlazor.Localizer["Page.执照中文"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_LicenseUs" Text="@WtmBlazor.Localizer["Page.执照拼音"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_LicenseCode" Text="@WtmBlazor.Localizer["Page.执照代码"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_License" Text="@WtmBlazor.Localizer["Page.执照时间"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_MailingAddress" Text="@WtmBlazor.Localizer["Page.邮寄地址"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_MailingZipCode" Text="@WtmBlazor.Localizer["Page.邮寄邮编"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_BelongingName" Text="@WtmBlazor.Localizer["Page.代理"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_LicenseAddress" Text="@WtmBlazor.Localizer["Page.营业执照地址"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_LicenseZipCode" Text="@WtmBlazor.Localizer["Page.营业执照邮编"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_CreateTime" Text="@WtmBlazor.Localizer["_Admin.CreateTime"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_UpdateTime" Text="@WtmBlazor.Localizer["_Admin.UpdateTime"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_CreateBy" Text="@WtmBlazor.Localizer["_Admin.CreateBy"]" />
    <TableColumn @bind-Field="@context.AmazonUserInfo_UpdateBy" Text="@WtmBlazor.Localizer["_Admin.UpdateBy"]" />
  </TableColumns>

  <RowButtonTemplate>
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/Edit"))
    {
        <TableCellButton Size="Size.ExtraSmall" Icon="fa fa-pencil-square" Color="Color.Warning" Text="@WtmBlazor.Localizer["Sys.Edit"]"  OnClick="()=>OnEditClick(context)" />
    }
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/{id}"))
    {
        <TableCellButton Size="Size.ExtraSmall" Icon="fa fa-info-circle" Color="Color.Info" Text="@WtmBlazor.Localizer["Page.详情"]"  OnClick="()=>OnDetailsClick(context)" />
    }
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/BatchDelete"))
    {
        <PopConfirmButton OnConfirm="() => OnDeleteClick(context)" Size="Size.ExtraSmall" Icon="fa fa-trash" Color="Color.Danger" Text="@WtmBlazor.Localizer["Sys.Delete"]" Content="@WtmBlazor.Localizer["Sys.DeleteConfirm"]" CloseButtonText="@WtmBlazor.Localizer["Sys.Close"]" ConfirmButtonText="@WtmBlazor.Localizer["Sys.Delete"]" 
            ConfirmButtonColor="Color.Danger" />
    }
  </RowButtonTemplate>
  <TableToolbarTemplate>
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/Create"))
    {
        <TableToolbarButton TItem="AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View" Icon="fa fa-plus" Color="Color.Primary" Text="@WtmBlazor.Localizer["Sys.Create"]"  OnClickCallback="(x)=>OnCreateClick()" />
    }
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/BatchDelete"))
    {
        <TableToolbarPopConfirmButton TItem="AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View"
             Icon="fa fa-trash" Color="Color.Danger" Text="@WtmBlazor.Localizer["Sys.Delete"]" Content="@WtmBlazor.Localizer["Sys.BatchDeleteConfirm"]" CloseButtonText="@WtmBlazor.Localizer["Sys.Close"]" ConfirmButtonText="@WtmBlazor.Localizer["Sys.BatchDelete"]" 
            OnConfirm="@OnBatchDeleteClick" ConfirmButtonColor="Color.Danger"/>
    }
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/BatchEdit"))
    {
        <TableToolbarButton TItem="AmazonTools.ViewModel._Admin.AmazonUserInfoVMs.AmazonUserInfo_View" Icon="fa fa-pencil-square" Color="Color.Primary" Text="@WtmBlazor.Localizer["Sys.BatchEdit"]"  OnClickCallback="(x)=>OnBatchEditClick()" />
    }
    @if (IsAccessable("/api/_Admin/AmazonUserInfo/Import"))
