
@page "/_Admin/AmazonUserInfo/Details"
@using AmazonTools.ViewModel._Admin.AmazonUserInfoVMs
@using System.ComponentModel.DataAnnotations
@inherits BasePage

<div>
  <ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit" >
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">
      <Display @bind-Value="@Model.Entity.FaUserNameCn"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.FaUserNameUs"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.FaIdCard"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.FaBornTime"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.FaEndTime"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.LicenseCn"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.LicenseUs"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.LicenseCode"  ShowLabel="true" IsDisabled="true"/>
      <WTUploadImage @bind-Value="@Model.Entity.LicensePhotoId" IsDisabled="true" thumb-width="128"/>
      <WTUploadImage @bind-Value="@Model.Entity.IDCardPhotoZId" IsDisabled="true" thumb-width="128"/>
      <WTUploadImage @bind-Value="@Model.Entity.IDCardPhotoFId" IsDisabled="true" thumb-width="128"/>
      <Display @bind-Value="@Model.Entity.License"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.MailingAddress"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.MailingZipCode"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.BelongingName"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.LicenseAddress"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.LicenseZipCode"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.CreateTime"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.UpdateTime"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.CreateBy"  ShowLabel="true" IsDisabled="true"/>
      <Display @bind-Value="@Model.Entity.UpdateBy"  ShowLabel="true" IsDisabled="true"/>
    </Row>

    <div class="modal-footer table-modal-footer">
      <Button OnClick="OnClose" Text="@WtmBlazor.Localizer["Sys.Close"]"/>
    </div>

  </ValidateForm>

</div>



@code {
    [Parameter]
    public string id { get; set; }
    [Parameter]
    public string[] ids { get; set; }
    private AmazonUserInfoVM Model = new AmazonUserInfoVM();
    private ValidateForm vform { get; set; }
    private async Task Submit(EditContext context)
    {
                        
        
        await PostsForm(vform, "/api/_Admin/AmazonUserInfo/Edit", (s) => "Sys.OprationSuccess");
    }
    public void OnClose()
    {
        CloseDialog();
    }
    
    protected override async Task OnInitializedAsync()
    {
        
        
        if (id != "")
        {
            var rv = await WtmBlazor.Api.CallAPI<AmazonUserInfoVM>($"/api/_Admin/AmazonUserInfo/{id}");
            Model = rv.Data;
        }

        await base.OnInitializedAsync();
    }
}
