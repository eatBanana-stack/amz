
@page "/_Admin/AmazonSiteInfo/Edit"
@using AmazonTools.ViewModel._Admin.AmazonSiteInfoVMs
@using System.ComponentModel.DataAnnotations
@inherits BasePage

<div>
  <ValidateForm @ref="vform" Model="@Model" OnValidSubmit="@Submit" >
    <Row ItemsPerRow="ItemsPerRow.Two" RowType="RowType.Normal">
      <Select @bind-Value="@Model.Entity.SiteName" PlaceHolder="@WtmBlazor.Localizer["Sys.PleaseSelect"]" Id="g965226e56ec04c59927b76e49ac2bc1e"/>
      <BootstrapInput @bind-Value="@Model.Entity.Mail"/>
      <BootstrapInput @bind-Value="@Model.Entity.MailPassWord"/>
      <BootstrapInput @bind-Value="@Model.Entity.AccountPassWord"/>
      <BootstrapInput @bind-Value="@Model.Entity.CreditCard"/>
      <BootstrapInput @bind-Value="@Model.Entity.SecurityCode"/>
      <BootstrapInput @bind-Value="@Model.Entity.ValidityPeriod"/>
      <BootstrapInput @bind-Value="@Model.Entity.Phone"/>
      <Select @bind-Value="@Model.Entity.AmazonState" PlaceHolder="@WtmBlazor.Localizer["Sys.PleaseSelect"]" Id="g5b4ee0e7dc164c67aadcd7d7dd7f7d3f"/>
      <Select @bind-Value="@Model.Entity.AmazonUserId" Items="AllAmazonUsers" PlaceHolder="@WtmBlazor.Localizer["Sys.PleaseSelect"]" Id="g36ddb5d0287f400aae34e086a7fd237b"/>
      <WTUploadFile @bind-Value="@Model.Entity.GooogleVerificationId"/>
    </Row>

    <div class="modal-footer table-modal-footer">
      <Button ButtonType="ButtonType.Submit" IsAsync="true" Text="@WtmBlazor.Localizer["Sys.Submit"]"/>
      <Button OnClick="OnClose" Text="@WtmBlazor.Localizer["Sys.Close"]"/>
    </div>

  </ValidateForm>

</div>



@code {
    [Parameter]
    public string id { get; set; }
    [Parameter]
    public string[] ids { get; set; }
    private AmazonSiteInfoVM Model = new AmazonSiteInfoVM();
    private ValidateForm vform { get; set; }
    private async Task Submit(EditContext context)
    {
                        
        
        await PostsForm(vform, "/api/_Admin/AmazonSiteInfo/Edit", (s) => "Sys.OprationSuccess", method: HttpMethodEnum.PUT);
    }
    public void OnClose()
    {
        CloseDialog();
    }
    
    private List<SelectedItem> AllAmazonUsers = new List<SelectedItem>();
    protected override async Task OnInitializedAsync()
    {
        
        
        AllAmazonUsers = await WtmBlazor.Api.CallItemsApi("/api/_Admin/AmazonSiteInfo/GetAmazonUserInfos");
        AllAmazonUsers.Insert(0, new SelectedItem { Text = WtmBlazor.Localizer["Sys.PleaseSelect"],Value = "" });
        if (id != "")
        {
            var rv = await WtmBlazor.Api.CallAPI<AmazonSiteInfoVM>($"/api/_Admin/AmazonSiteInfo/{id}");
            Model = rv.Data;
        }

        await base.OnInitializedAsync();
    }
}
