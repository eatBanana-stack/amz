<Window
    x:Class="AmazonTools.Desktop.EndPackaged"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:AmazonTools.Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="打包材料"
    Width="220"
    Height="250"
    ResizeMode="NoResize"
    mc:Ignorable="d">

    <DockPanel Margin="15" VerticalAlignment="Center">
        <ComboBox
            x:Name="cb_State"
            Width="150"
            Margin="0,10"
            hc:InfoElement.Title="状态:"
            hc:InfoElement.TitlePlacement="Left"
            DockPanel.Dock="Top"
            Style="{DynamicResource ComboBoxExtend}"
            Text="" />

        <Button
            x:Name="lb_xk"
            Width="150"
            Margin="0,10"
            hc:InfoElement.Title="状态:"
            hc:InfoElement.TitlePlacement="Left"
            Click="lb_xk_Click"
            Content=""
            DockPanel.Dock="Top"
            Style="{DynamicResource ButtonDashedPrimary}" />
        <Button
            Width="140"
            Margin="0,30"
            Click="Button_Click_Add"
            Content="打包"
            DockPanel.Dock="Top"
            Style="{DynamicResource ButtonSuccess}" />
    </DockPanel>

</Window>
