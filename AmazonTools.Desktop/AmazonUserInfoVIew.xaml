<UserControl
    x:Class="AmazonTools.Desktop.AmazonUserInfoVIew"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:AmazonTools.Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="720"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="tb_UserName"
            Width="200"
            Margin="10"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="姓名："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_IdCard"
            Width="200"
            Margin="260,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="身份证："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <Button
            Grid.Row="0"
            Margin="500,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Button_Click_slect"
            Content="查询"
            Style="{DynamicResource ButtonSuccess}" />
        <!--<Button
            Grid.Row="0"
            Margin="500,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Content="修改"
            Style="{DynamicResource ButtonPrimary}" />-->
        <!--<Button
            Grid.Row="0"
            Width="100"
            Margin="580,0,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            Click="Button_Click_Add"
            Content="添加客户信息"
            Style="{DynamicResource ButtonWarning}" />-->
        <hc:TransitioningContentControl Grid.Row="1">
            <TabControl>
                <TabItem Header="数据表格">
                    <DataGrid
                        x:Name="dg_filter"
                        hc:DataGridAttach.CanUnselectAllWithBlankArea="True"
                        AutoGenerateColumns="False"
                        HeadersVisibility="All"
                        RowHeaderWidth="60">
                        <!--<DataGrid.Resources>
                        -->
                        <!--  表头居中样式  -->
                        <!--
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                                <Setter Property="FontWeight" Value="Bold" />
                        -->
                        <!--<Setter Property="Background" Value="#FFE0E0E0" />-->
                        <!--
                                <Setter Property="Padding" Value="5" />
                            </Style>
                        </DataGrid.Resources>-->
                        <DataGrid.RowHeaderTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" />
                            </DataTemplate>
                        </DataGrid.RowHeaderTemplate>
                        <DataGrid.Columns>


                            <DataGridTextColumn
                                Binding="{Binding FaUserNameCn}"
                                CanUserResize="False"
                                Header="姓名"
                                IsReadOnly="True" />

                            <DataGridTemplateColumn
                                Width="180"
                                CanUserResize="False"
                                Header="营业执照">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Width="150"
                                            Height="30"
                                            Click="Button_Click_YYZZ"
                                            Content="{Binding LicensePhotoId}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn
                                Width="180"
                                CanUserResize="False"
                                Header="身份证正面">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Width="150"
                                            Height="30"
                                            Click="Button_Click_dowSfz"
                                            Content="{Binding IDCardPhotoZId}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn
                                Width="180"
                                CanUserResize="False"
                                Header="身份证反面">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                            Width="150"
                                            Height="30"
                                            Click="Button_Click_dowSfzf"
                                            Content="{Binding IDCardPhotoFId}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </hc:TransitioningContentControl>
    </Grid>
</UserControl>
