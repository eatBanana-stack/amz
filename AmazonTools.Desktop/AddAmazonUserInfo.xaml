<hc:Window
    x:Class="AmazonTools.Desktop.AddAmazonUserInfo"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="添加客户信息"
    Width="800"
    Height="550"
    ResizeMode="NoResize"
    mc:Ignorable="d">
    <Grid Margin="10,0,10,20">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="tb_FaUserNameCn"
            Grid.Row="0"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="姓名中文："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_FaUserNameUs"
            Grid.Row="0"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="姓名拼音："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />


        <TextBox
            x:Name="tb_FaIdCard"
            Grid.Row="1"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="身份证号码："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
     x:Name="tb_shouji"
     Grid.Row="1"
     Width="300"
     HorizontalAlignment="Right"
     VerticalAlignment="Center"
     hc:InfoElement.Title="手机号："
     hc:InfoElement.TitlePlacement="Left"
     Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_FaBornTime"
            Grid.Row="2"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="出生时间："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_FaEndTime"
            Grid.Row="2"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="有效时间："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />





        <TextBox
            x:Name="tb_LicenseCn"
            Grid.Row="3"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照中文："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_LicenseUs"
            Grid.Row="3"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照拼音："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_LicenseCode"
            Grid.Row="4"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照代码："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_License"
            Grid.Row="4"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照时间："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_MailingZipCode"
            Grid.Row="5"
            Width="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <Button
            Grid.Row="5"
            Margin="200,0,0,0"
            HorizontalAlignment="Left"
            Click="Button_Click_zipCode"
            Content="加载地址邮编" />
        <TextBox
            x:Name="tb_MailingAddress"
            Grid.Row="5"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="邮寄地址："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_LicenseZipCode"
            Grid.Row="6"
            Width="200"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <Button
            Grid.Row="6"
            Margin="200,0,0,0"
            HorizontalAlignment="Left"
            Click="Button_Click_loadZipCode"
            Content="加载执照邮编" />
        <TextBox
            x:Name="tb_LicenseAddress"
            Grid.Row="6"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照地址："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />


        <Grid Grid.Row="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="265" />
                <ColumnDefinition Width="265" />
                <ColumnDefinition Width="265" />

            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" HorizontalAlignment="Left">
                <!--  预览区域  -->
                <Label
                    x:Name="lb_IDCardPhotoZId"
                    Width="100"
                    Content="未上传文件" />
                <!--  操作按钮  -->
                <Button
                    Margin="10"
                    Click="Button_Click_sfz"
                    Content="选择身份证正面" />
            </DockPanel>
            <DockPanel Grid.Column="1" HorizontalAlignment="Left">
                <!--  预览区域  -->
                <!--  操作按钮  -->
                <Label
                    x:Name="lb_IDCardPhotoFId"
                    Width="100"
                    Content="未上传文件" />
                <Button
                    Margin="10"
                    Click="Button_Click_sfb"
                    Content="选择身份证背面" />

            </DockPanel>
            <DockPanel Grid.Column="2" HorizontalAlignment="Left">
                <!--  预览区域  -->
                <Label
                    x:Name="lb_LicensePhotoId"
                    Width="100"
                    Content="未上传文件" />
                <!--  操作按钮  -->
                <Button
                    Margin="10"
                    Click="Button_Click_yyzz"
                    Content="选择营业执照" />
            </DockPanel>
        </Grid>

        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <ComboBox
                x:Name="cb_youxian"
                Grid.Column="0"
                Width="180"
                Margin="10,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                hc:InfoElement.Title="邮箱设置："
                hc:InfoElement.TitlePlacement="Left"
                Style="{DynamicResource ComboBoxExtend}" />
            <ComboBox
                x:Name="cb_xinka"
                Grid.Column="1"
                Width="180"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                hc:InfoElement.Title="信用卡设置："
                hc:InfoElement.TitlePlacement="Left"
                Style="{DynamicResource ComboBoxExtend}" />
            <ComboBox
                x:Name="cb_zhandian"
                Grid.Column="2"
                Width="180"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                hc:InfoElement.Title="站点设置："
                hc:InfoElement.TitlePlacement="Left"
                Style="{DynamicResource ComboBoxExtend}" />
            <ComboBox
                x:Name="Cb_BelongingNameId"
                Grid.Column="3"
                Width="180"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                hc:InfoElement.Title="代理："
                hc:InfoElement.TitlePlacement="Left"
                Style="{DynamicResource ComboBoxExtend}" />
        </Grid>

        <Button
            Grid.Row="9"
            Width="180"
            Height="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Button_Click_Add"
            Content="提交材料"
            FontSize="24"
            Style="{DynamicResource ButtonSuccess}" />
    </Grid>
</hc:Window>
