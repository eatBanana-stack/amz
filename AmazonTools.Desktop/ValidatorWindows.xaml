<hc:Window
    x:Class="AmazonTools.Desktop.ValidatorWindows"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:AmazonTools.Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="ValidatorWindows"
    Width="800"
    Height="600"
    ResizeMode="NoResize"
    mc:Ignorable="d">

    <Grid Margin="10,0,10,20">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="60" />
            <RowDefinition Height="25" />
            <RowDefinition />

        </Grid.RowDefinitions>
        <TextBox
            x:Name="tb_FaUserNameCn"
            Grid.Row="0"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="姓名中文："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_FaUserNameCn_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_FaUserNameUs"
            Grid.Row="0"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="姓名拼音："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_FaUserNameUs_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />


        <TextBox
            x:Name="tb_FaIdCard"
            Grid.Row="1"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="身份证号码："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_FaIdCard_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
      x:Name="tb_shouji"
      Grid.Row="1"
      Width="300"
      HorizontalAlignment="Right"
      VerticalAlignment="Center"
      hc:InfoElement.Title="手机号码："
      hc:InfoElement.TitlePlacement="Left"
      BorderBrush="Red"
      BorderThickness="2"
     MouseDoubleClick="tb_shouji_MouseDoubleClick"
      Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_FaBornTime"
            Grid.Row="2"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="出生时间："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_FaEndTime"
            Grid.Row="2"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="有效时间："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />





        <TextBox
            x:Name="tb_LicenseCn"
            Grid.Row="3"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照中文："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_LicenseCn_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_LicenseUs"
            Grid.Row="3"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照拼音："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_LicenseUs_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_LicenseCode"
            Grid.Row="4"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照代码："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_LicenseCode_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_License"
            Grid.Row="4"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照时间："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_LicenseZipCode"
            Grid.Row="5"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照邮编："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_LicenseZipCode_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_LicenseAddress"
            Grid.Row="5"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="执照地址："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_LicenseAddress_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_MailingZipCode"
            Grid.Row="6"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="身份邮编："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_MailingZipCode_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_MailingAddress"
            Grid.Row="6"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="身份地址："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Red"
            BorderThickness="2"
            MouseDoubleClick="tb_MailingAddress_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_Mail"
            Grid.Row="7"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="账号："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Green"
            BorderThickness="2"
            MouseDoubleClick="tb_Mail_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />
        <Button
          x:Name="TbShouEmail"
          Grid.Row="7"
          Content="收取邮件"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          hc:InfoElement.TitlePlacement="Left"
            Click="TbShouEmail_Click"
          FontSize="14"
          Style="{DynamicResource ButtonSuccess}" />
        <TextBox
            x:Name="tb_AccountPassWord"
            Grid.Row="7"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="密码："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Green"
            BorderThickness="2"
            MouseDoubleClick="tb_AccountPassWord_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />


        <TextBox
            x:Name="tb_CreditCard"
            Grid.Row="8"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="信用卡："
            hc:InfoElement.TitlePlacement="Left"
            BorderBrush="Green"
            BorderThickness="2"
            MouseDoubleClick="tb_CreditCard_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />

        <Button

  Grid.Row="8"
  Content="获取照片"
  HorizontalAlignment="Center"
  VerticalAlignment="Center"
  hc:InfoElement.TitlePlacement="Left"
    Click="Button_Click"
  FontSize="14"
  Style="{DynamicResource ButtonSuccess}" />
        <TextBox
            x:Name="tb_SecurityCode"
            Grid.Row="8"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="安全码："
            hc:InfoElement.TitlePlacement="Left"
            MouseDoubleClick="tb_SecurityCode_MouseDoubleClick"
            Style="{DynamicResource TextBoxExtend}" />

        <TextBox
            x:Name="tb_MailPassWord"
            Grid.Row="9"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.Title="邮箱密码："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <TextBox
            x:Name="tb_ValidityPeriod"
            Grid.Row="9"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.Title="有效期："
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBoxExtend}" />
        <!--<Button
            Grid.Row="10"
            Width="180"
            Height="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Button_Click_jietu"
            Content="点击截图"
            FontSize="24"
            Style="{DynamicResource ButtonSuccess}" />-->
        <TextBlock
            x:Name="TbAccountInfo"
            Grid.Row="10"
            Width="300"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.TitlePlacement="Left"
            Style="{DynamicResource TextBlockDefault}"
            Text="未绑定账户" />
        <Button
            x:Name="BtnSelectImage"
            Grid.Row="10"
            Width="300"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.TitlePlacement="Left"
            Click="BtnSelectImage_Click"
            Content="点击粘贴二维码图片"
            FontWeight="Bold"
            Style="{DynamicResource ButtonDashedDanger}" />

        <Button
            x:Name="TbVerificationCode"
            Grid.Row="11"
            Width="300"
            Height="50"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            hc:InfoElement.TitlePlacement="Left"
            Click="TbVerificationCode_Click_VerificationCode"
            FontSize="24"
            FontWeight="Bold"
            Style="{DynamicResource ButtonSuccess}" />
        <Button
            x:Name="TbCountdown"
            Grid.Row="11"
            Width="300"
            Height="50"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            hc:InfoElement.TitlePlacement="Left"
            Content="30秒"
            Style="{DynamicResource ButtonDanger}" />
        <ProgressBar
            x:Name="PbCountdown"
            Grid.Row="12"
            Height="10"
            Maximum="30"
            Minimum="0" />

        <Button
            Grid.Row="13"
            Width="180"
            Height="50"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="Button_Click_update"
            Content="修改材料"
            FontSize="24"
            Style="{DynamicResource ButtonSuccess}" />
    </Grid>

</hc:Window>
