<Window
    x:Class="AmazonTools.Desktop.UpdateState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:local="clr-namespace:AmazonTools.Desktop"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="修改状态"
    Width="220"
    Height="220"
    ResizeMode="NoResize"
    mc:Ignorable="d">
    <DockPanel
        Grid.Column="1"
        Margin="15"
        VerticalAlignment="Center">
        <ComboBox
            x:Name="cb_State"
            Margin="0,10"
            hc:InfoElement.Title="状态:"
            hc:InfoElement.TitlePlacement="Left"
            DockPanel.Dock="Top"
            Style="{DynamicResource ComboBoxExtend}"
            Text="" />


        <Button
            Width="100"
            Margin="0,40"
            Click="Button_Click_Add"
            Content="保存"
            DockPanel.Dock="Top"
            Style="{DynamicResource ButtonSuccess}" />
    </DockPanel>

</Window>
